{
  "description": "Sentient Sims companion app",
  "keywords": [
    "electron",
    "boilerplate",
    "react",
    "typescript",
    "ts",
    "sass",
    "webpack",
    "hot",
    "reload"
  ],
  "type": "module",
  "homepage": "https://github.com/guspuffygit/sentient-sims-app#readme",
  "bugs": {
    "url": "https://github.com/guspuffygit/sentient-sims-app/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guspuffygit/sentient-sims-app.git"
  },
  "license": "MIT",
  "author": {
    "name": "Gus Puffy",
    "url": "https://www.sentientsimulations.com"
  },
  "contributors": [],
  "main": "./release/app/dist/main/main.js",
  "scripts": {
    "build": "electron-vite build",
    "compile": "npx tsc --noEmit --skipLibCheck",
    "checknativedeps": "node .erb/scripts/check-native-dep.ts",
    "postinstall": "npm run checknativedeps && cross-env electron-builder install-app-deps",
    "lint": "cross-env NODE_ENV=development eslint --flag unstable_native_nodejs_ts_config .",
    "package": "node ./.erb/scripts/clean.ts dist && npm run build && cross-env electron-builder build --publish never",
    "rebuild": "cross-env electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
    "start": "cross-env NODE_ENV=development electron-vite dev",
    "test": "cross-env NODE_ENV=test ELECTRON_RUN_AS_NODE=true ./node_modules/.bin/electron ./node_modules/.bin/vitest run --coverage",
    "test:single": "cross-env NODE_ENV=test ELECTRON_RUN_AS_NODE=true ./node_modules/.bin/electron ./node_modules/.bin/vitest run Formatter",
    "test:e2e": "cross-env NODE_ENV=test ELECTRON_RUN_AS_NODE=true ./node_modules/.bin/electron ./node_modules/.bin/vitest run ChromeDriver.e2e",
    "test:api": "cross-env NODE_ENV=test ELECTRON_RUN_AS_NODE=true ./node_modules/.bin/electron ./node_modules/.bin/vitest run Api.test",
    "test:unit": "cross-env NODE_ENV=test ELECTRON_RUN_AS_NODE=true ./node_modules/.bin/electron ./node_modules/.bin/vitest run --exclude '**/*.it.test.ts' --exclude '**/*.e2e.test.ts'",
    "test:watch": "cross-env NODE_ENV=test ELECTRON_RUN_AS_NODE=true ./node_modules/.bin/electron ./node_modules/.bin/vitest --exclude '**/*.it.test.ts' --exclude '**/*.e2e.test.ts'",
    "as-electron": "ELECTRON_RUN_AS_NODE=true electron",
    "check": "npm run lint && npm run compile && npm run test"
  },
  "browserslist": [],
  "prettier": {
    "singleQuote": true,
    "quoteProps": "consistent",
    "trailingComma": "all",
    "printWidth": 120
  },
  "dependencies": {
    "@aws-amplify/auth": "^6.20.0",
    "@aws-amplify/ui-react": "^6.15.4",
    "@aws-sdk/client-s3": "^3.347.1",
    "@aws-sdk/credential-provider-node": "^3.501.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@google-cloud/text-to-speech": "^5.8.1",
    "@google/genai": "^1.34.0",
    "@mui/icons-material": "^9.1.0",
    "@mui/lab": "^9.0.0-beta.4",
    "@mui/material": "^9.1.0",
    "@mui/x-data-grid": "^9.4.0",
    "@nem035/gpt-3-encoder": "^1.1.7",
    "@patternfly/react-core": "^6.4.0",
    "@patternfly/react-log-viewer": "^6.3.0",
    "@patternfly/react-styles": "^6.4.0",
    "@tanstack/react-query": "^5.90.11",
    "adm-zip": "^0.5.10",
    "aws-amplify": "^6.18.0",
    "axios": "^1.18.0",
    "electron-debug": "^3.2.0",
    "electron-log": "^5.4.4",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.0.6",
    "jwt-decode": "^3.1.2",
    "openai": "^5.0.0-alpha.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.10.0",
    "react-window": "^1.8.9",
    "sharp": "^0.34.5",
    "source-map-support": "^0.5.21",
    "vkbeautify": "^0.99.3",
    "xml2js": "^0.6.0"
  },
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.693.0",
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.4",
    "@eslint-react/eslint-plugin": "^5.8.17",
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.0",
    "@types/adm-zip": "^0.5.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/node-abi": "^3.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-test-renderer": "^19.1.0",
    "@types/react-window": "^1.8.8",
    "@types/request": "^2.48.8",
    "@types/selenium-webdriver": "^4.1.21",
    "@types/source-map-support": "^0.5.10",
    "@types/vkbeautify": "^0.99.4",
    "@types/xml2js": "^0.4.11",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@webgpu/types": "^0.1.55",
    "better-sqlite3": "12.10.0",
    "chalk": "^4.1.2",
    "core-js": "^3.27.2",
    "cross-env": "^7.0.3",
    "detect-port": "^2.1.0",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.2",
    "electron-chromedriver": "^41.7.2",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "node-abi": "^4.31.0",
    "prettier": "^3.8.4",
    "react-syntax-highlighter": "^16.1.1",
    "react-test-renderer": "^19.2.1",
    "rimraf": "^4.1.2",
    "selenium-webdriver": "^4.17.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.3.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "uuid": "9.0.1"
  },
  "optionalDependencies": {
    "dmg-license": "1.0.11"
  },
  "build": {
    "productName": "SentientSims",
    "appId": "com.sentientsimulations.sentientsimsapp",
    "asar": true,
    "asarUnpack": "**\\*.{node,dll}",
    "afterPack": "./myAfterPackHook.ts",
    "npmRebuild": false,
    "files": [
      "dist",
      "node_modules",
      "package.json"
    ],
    "afterSign": ".erb/scripts/notarize.ts",
    "mac": {
      "target": {
        "target": "default",
        "arch": [
          "universal"
        ]
      },
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    },
    "directories": {
      "app": "release/app",
      "buildResources": "assets",
      "output": "release/build"
    },
    "extraResources": [
      "./assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "guspuffygit",
      "repo": "sentient-sims-app"
    }
  }
}
